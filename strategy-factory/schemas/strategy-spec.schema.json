{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategySpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategy_id",
    "version",
    "name",
    "structure_type",
    "underlyings",
    "timeframe",
    "entry_window",
    "regime_filters",
    "legs",
    "position_sizing",
    "adjustments",
    "exits",
    "cost_model",
    "risk_limits",
    "validation_plan"
  ],
  "properties": {
    "strategy_id": {"type": "string", "minLength": 3},
    "version": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 3},
    "structure_type": {
      "type": "string",
      "enum": ["SINGLE", "VERTICAL", "STRADDLE", "STRANGLE", "IRON_CONDOR", "CALENDAR", "BUTTERFLY", "RATIO"]
    },
    "underlyings": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "timeframe": {"type": "object"},
    "entry_window": {
      "type": "object",
      "required": ["timezone", "first_trade_time", "last_new_entry_time"],
      "properties": {
        "timezone": {"type": "string"},
        "first_trade_time": {"type": "string"},
        "last_new_entry_time": {"type": "string"}
      }
    },
    "regime_filters": {"type": "object"},
    "legs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["side", "option_type", "expiry_rule", "strike_rule", "qty_ratio"],
        "properties": {
          "side": {"type": "string", "enum": ["BUY", "SELL"]},
          "option_type": {"type": "string", "enum": ["CALL", "PUT"]},
          "expiry_rule": {"type": "object"},
          "strike_rule": {"type": "object"},
          "qty_ratio": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    },
    "position_sizing": {"type": "object"},
    "adjustments": {"type": "object"},
    "exits": {"type": "object"},
    "cost_model": {"type": "object"},
    "risk_limits": {"type": "object"},
    "validation_plan": {"type": "object"},
    "meta": {"type": "object"}
  }
}
